# vLLM server
VLLM_PORT=8005
HF_HOME=/data/all_cache/hf_home
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# GPU selection (comma-separated GPU IDs)
NVIDIA_VISIBLE_DEVICES=0          # single GPU for 9B
# NVIDIA_VISIBLE_DEVICES=0,1      # 2 GPUs for 27B FP8

# Model config (defaults to 9B BF16 on 1 GPU)
VALIDATOR_MODEL=Qwen/Qwen3.5-9B
VALIDATOR_TP=1
VALIDATOR_DTYPE=bfloat16
# --- 27B FP8 on 2 GPUs ---
# VALIDATOR_MODEL=Qwen/Qwen3.5-27B-FP8
# VALIDATOR_TP=2
# VALIDATOR_DTYPE=auto

# Client
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=Qwen/Qwen3.5-9B
